@model IEnumerable<BusTicketSystem.MVC.ViewModels.ReviewResponseViewModel>

@{
    ViewData["Title"] = "My Reviews";
}

<div class="container mt-4">
    <h2>My Reviews</h2>
    <hr />

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var review in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@review.TripName</h5>
                            <h6 class="card-subtitle mb-2 text-muted">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span class="text-warning">★</span>
                                }
                                @for (int i = review.Rating; i < 5; i++)
                                {
                                    <span class="text-secondary">★</span>
                                }
                                - @review.ReviewDate.ToString("MMM dd, yyyy")
                            </h6>
                            <p class="card-text mt-3">
                                @(string.IsNullOrEmpty(review.Comment) ? "No comment provided." : review.Comment)
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0 text-end">
                            <a href="@Url.Action("Edit", "Review", new { id = review.ReviewId })" class="btn btn-sm btn-outline-primary">Edit Review</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            You haven't written any reviews yet.
        </div>
    }
</div>
