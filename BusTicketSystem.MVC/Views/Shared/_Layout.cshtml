<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoyaBus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --vb-primary: #475569;
            --vb-accent: #6366f1;
            --vb-dark: #0f172a;
            --vb-light: #f8fafc;
            --vb-border: #e2e8f0;
        }
        body { font-family: 'Outfit', sans-serif; background-color: #f8fafc; color: #0f172a; }
        .navbar { background: white; border-bottom: 1px solid var(--vb-border); height: 72px; }
        .vb-logo { font-weight: 700; color: #334155; font-size: 1.4rem; letter-spacing: -0.5px; }
        .nav-link { font-weight: 500; color: #64748b !important; font-size: 0.95rem; }
        .nav-link.active { color: #0f172a !important; border-bottom: 2px solid #6366f1; }
        .btn-register { background: #475569; color: white; border-radius: 6px; font-weight: 600; padding: 8px 20px; }
        .btn-register:hover { background: #334155; color: white; }
        .footer { background: #f1f5f9; padding: 40px 0; border-top: 1px solid var(--vb-border); }
        .footer-logo { font-weight: 700; color: #334155; font-size: 1.2rem; }
        .footer-link { color: #64748b; text-decoration: none; font-size: 0.9rem; }
        .footer-link:hover { color: #0f172a; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand vb-logo" asp-controller="Home" asp-action="Index">VoyaBus</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link px-3 @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trips" ? "active" : "")" asp-controller="Trips" asp-action="Index">Find Trips</a></li>
                        <li class="nav-item"><a class="nav-link px-3 @(ViewContext.RouteData.Values["Action"]?.ToString() == "MyBookings" ? "active" : "")" asp-controller="Booking" asp-action="MyBookings">Manage Booking</a></li>
                        <li class="nav-item"><a class="nav-link px-3" href="#">Travel Alerts</a></li>
                        <li class="nav-item"><a class="nav-link px-3" href="#">Support</a></li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @using BusTicketSystem.MVC.Helper
                        @inject IHttpContextAccessor HttpContextAccessor
                        @{
                            var userRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
                            var jwtToken = HttpContextAccessor.HttpContext?.Session.GetString("JwtToken");
                            var isValid = TokenHelper.IsTokenValid(jwtToken!);
                        }

                        @if (isValid)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-dark rounded-pill px-4 dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-2"></i> @userRole
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2 mt-2">
                                    @if (userRole == "Agency")
                                    {
                                        <li><a class="dropdown-item rounded-2" asp-controller="Dashboard" asp-action="Agency">Dashboard</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Bus" asp-action="Index">Manage Fleet</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Routes" asp-action="Index">Manage Routes</a></li>
                                    }
                                    else if (userRole == "Admin")
                                    {
                                        <li><a class="dropdown-item rounded-2 fw-bold text-primary" asp-controller="Admin" asp-action="Dashboard">Admin Dashboard</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Admin" asp-action="Users">Manage Users</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Admin" asp-action="Agencies">Agencies Audit</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item rounded-2" asp-controller="Dashboard" asp-action="Customer">My Trips</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Booking" asp-action="MyBookings">Bookings</a></li>
                                        <li><a class="dropdown-item rounded-2" asp-controller="Profile" asp-action="Index">Profile</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item rounded-2 text-danger" asp-controller="Auth" asp-action="Logout">Logout</a></li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="nav-link px-3" asp-controller="Auth" asp-action="LoginCustomer">Sign In</a>
                            <a class="btn btn-register" asp-controller="Auth" asp-action="RegisterCustomer">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-4">
                <div class="footer-logo">VoyaBus</div>
                <div class="d-flex gap-4">
                    <a href="#" class="footer-link">Privacy Policy</a>
                    <a href="#" class="footer-link">Terms of Service</a>
                    <a href="#" class="footer-link">Cookie Settings</a>
                    <a href="#" class="footer-link">Partner Portal</a>
                    <a href="#" class="footer-link">Sitemap</a>
                </div>
                <div class="text-muted small">© @DateTime.Now.Year VoyaBus Transit Systems. All rights reserved.</div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
