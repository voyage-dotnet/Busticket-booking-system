<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoyaBus</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="vb-bg-page">
    <header>
        <nav class="navbar navbar-expand-sm vb-navbar sticky-top">
            <div class="container">
                <a class="vb-navbar-brand" asp-controller="Home" asp-action="Index">VoyaBus</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="vb-nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trips" ? "active" : "")" asp-controller="Trips" asp-action="Index">Search Trips</a>
                        </li>
                        <li class="nav-item">
                            <a class="vb-nav-link" asp-controller="Offices" asp-action="AllAgencies">Our Partners</a>
                        </li>
                        <li class="nav-item">
                            <a class="vb-nav-link" asp-controller="TicketBooking" asp-action="MyBookings">Manage Booking</a>
                        </li>
                        <li class="nav-item">
                            <a class="vb-nav-link" asp-controller="Home" asp-action="TravelAlerts">Travel Alerts</a>
                        </li>
                        <li class="nav-item">
                            <a class="vb-nav-link" asp-controller="Home" asp-action="Support">Support</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center gap-3">
                        @using Microsoft.AspNetCore.Http
                        @inject IHttpContextAccessor HttpContextAccessor
                        @{
                            var userRole = HttpContextAccessor.HttpContext?.Session.GetString("UserRole");
                            var jwtToken = HttpContextAccessor.HttpContext?.Session.GetString("JwtToken");
                        }

                        @if (!string.IsNullOrEmpty(jwtToken))
                        {
                            <div class="dropdown">
                                <button class="vb-btn-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i> @userRole
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end vb-card shadow-lg p-2 mt-2 border-0">
                                    @if (userRole == "Agency")
                                    {
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Dashboard" asp-action="Agency">Dashboard</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Bus" asp-action="Index">Manage Fleet</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Routes" asp-action="Index">Manage Routes</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Trips" asp-action="Agency">Manage Trips</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Offices" asp-action="Index">Manage Offices</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2 text-primary" asp-controller="Payment" asp-action="Revenue">Financial Overview</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Dashboard" asp-action="Customer">My Trips</a></li>
                                        <li><a class="dropdown-item vb-nav-link rounded-2" asp-controller="Profile" asp-action="Index">Profile</a></li>
                                    }
                                    <li><hr class="dropdown-divider opacity-10"></li>
                                    <li>
                                        <form asp-controller="Auth" asp-action="Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger rounded-2 bg-transparent border-0 w-100 text-start">Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="vb-btn-ghost" asp-controller="Auth" asp-action="LoginCustomer">Sign In</a>
                            <a class="vb-btn-primary" asp-controller="Auth" asp-action="RegisterCustomer">Register</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm vb-radius-md" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm vb-radius-md" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="vb-bg-panel py-5 border-top">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 mb-4 mb-md-0">
                    <a class="vb-navbar-brand mb-2 d-block text-decoration-none" asp-controller="Home" asp-action="Index">VoyaBus</a>
                    <p class="vb-text-muted small mb-0">© @DateTime.Now.Year VoyaBus Transit Systems.<br>All rights reserved.</p>
                </div>
                <div class="col-md-8">
                    <div class="d-flex flex-wrap justify-content-md-end gap-4">
                        <a href="#" class="vb-nav-link p-0 h-auto">Privacy Policy</a>
                        <a href="#" class="vb-nav-link p-0 h-auto">Terms of Service</a>
                        <a href="#" class="vb-nav-link p-0 h-auto">Cookie Settings</a>
                        <a asp-controller="Auth" asp-action="LoginAgency" class="vb-nav-link p-0 h-auto">Partner Portal</a>
                        <a href="#" class="vb-nav-link p-0 h-auto">Sitemap</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
