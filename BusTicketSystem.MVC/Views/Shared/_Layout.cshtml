<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoyaBus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="vb-navbar">
            <div class="container d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-4">
                    <a class="vb-navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">VoyaBus</a>
                    <div class="d-none d-md-flex">
                        <a class="vb-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trips" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-controller="Trips" asp-action="Index">Find Trips</a>
                        <a class="vb-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Trips" && ViewContext.RouteData.Values["action"]?.ToString() == "Manage" ? "active" : "")" asp-controller="Trips" asp-action="Manage">Manage Booking</a>
                        <a class="vb-nav-link" href="#">Travel Alerts</a>
                        <a class="vb-nav-link" href="#">Support</a>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <a href="#" class="vb-btn-ghost">Sign In</a>
                    <a href="#" class="vb-btn-primary">Register</a>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="vb-footer mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="vb-footer-brand">VoyaBus</div>
                    <div class="vb-footer-copy">&copy; @DateTime.Now.Year VoyaBus Transit Systems. All rights reserved.</div>
                </div>
                <div class="col-md-6">
                    <ul class="vb-footer-links justify-content-md-end">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Cookie Settings</a></li>
                        <li><a href="#">Partner Portal</a></li>
                        <li><a href="#">Sitemap</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
