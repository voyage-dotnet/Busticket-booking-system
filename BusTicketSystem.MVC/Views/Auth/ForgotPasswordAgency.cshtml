@model BusTicketSystem.MVC.ViewModels.UpdatePasswordViewModel
@{
    ViewData["Title"] = "Reset Agency Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="vb-card p-4 shadow-sm" style="border-radius: var(--vb-radius-lg); background: white;">
                <div class="text-center mb-4">
                    <div class="vb-icon-circle mb-3 mx-auto">
                        <i class="bi bi-building-lock fs-2 text-primary"></i>
                    </div>
                    <h2 class="fw-bold h3 mb-2">Change Agency Password</h2>
                    <p class="text-muted small">Update your agency account password</p>
                </div>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="ForgotPasswordAgency" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="vb-filter-label mb-1">Agency Email</label>
                        <input asp-for="Email" class="vb-search-input py-2" placeholder="Enter agency email" style="border-radius: var(--vb-radius-md);">
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="vb-filter-label mb-1">New Password</label>
                        <input asp-for="Password" type="password" class="vb-search-input py-2" placeholder="Enter new password" style="border-radius: var(--vb-radius-md);">
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="vb-filter-label mb-1">Confirm New Password</label>
                        <input asp-for="ConfirmPassword" type="password" class="vb-search-input py-2" placeholder="Confirm new password" style="border-radius: var(--vb-radius-md);">
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="vb-btn-primary justify-content-center py-3">
                            <i class="bi bi-check2-circle me-2"></i> Update Password
                        </button>
                        <a asp-action="Index" asp-controller="Home" class="vb-btn-ghost justify-content-center py-2 text-decoration-none">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
