@model BusTicketSystem.MVC.ViewModels.RegisterCustomerViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="vb-card p-4 p-lg-5 shadow-lg border-0">
                <div class="text-center mb-5">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block text-primary mb-3">
                        <i class="bi bi-person-plus h3 mb-0"></i>
                    </div>
                    <h2 class="fw-bold mb-1">Join VoyaBus</h2>
                    <p class="vb-text-muted">Start your journey with us today.</p>
                </div>

                <form asp-action="RegisterCustomer" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger vb-radius-md border-0 small mb-4"></div>

                    <div class="vb-form-group mb-4">
                        <label asp-for="Name" class="vb-form-label">Full Name</label>
                        <div class="position-relative">
                            <i class="bi bi-person position-absolute start-0 top-50 translate-middle-y ms-3 text-muted"></i>
                            <input asp-for="Name" class="vb-form-control ps-5" placeholder="Enter your full name" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="vb-form-group mb-4">
                        <label asp-for="Email" class="vb-form-label">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute start-0 top-50 translate-middle-y ms-3 text-muted"></i>
                            <input asp-for="Email" class="vb-form-control ps-5" placeholder="name@example.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="vb-form-group mb-4">
                        <label asp-for="PhoneNumber" class="vb-form-label">Phone Number</label>
                        <div class="position-relative">
                            <i class="bi bi-phone position-absolute start-0 top-50 translate-middle-y ms-3 text-muted"></i>
                            <input asp-for="PhoneNumber" class="vb-form-control ps-5" placeholder="+91 98765 43210" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="vb-form-group mb-4">
                        <label asp-for="Password" class="vb-form-label">Password</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-lock position-absolute start-0 top-50 translate-middle-y ms-3 text-muted"></i>
                            <input asp-for="Password" type="password" class="vb-form-control ps-5" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="vb-form-group mb-5">
                        <label asp-for="ConfirmPassword" class="vb-form-label">Confirm Password</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-check position-absolute start-0 top-50 translate-middle-y ms-3 text-muted"></i>
                            <input asp-for="ConfirmPassword" type="password" class="vb-form-control ps-5" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="vb-btn-primary w-100 py-3 mb-4 shadow-sm">
                        Create Account <i class="bi bi-arrow-right ms-2"></i>
                    </button>

                    <div class="text-center small">
                        <span class="vb-text-muted">Already have an account?</span>
                        <a asp-action="LoginCustomer" class="text-primary fw-bold text-decoration-none ms-1">Sign In</a>
                    </div>
                </form>
            </div>
            
            <p class="text-center vb-text-muted mt-5 small">
                By creating an account, you agree to our <br>
                <a href="#" class="text-decoration-none">Terms of Service</a> and <a href="#" class="text-decoration-none">Privacy Policy</a>
            </p>
        </div>
    </div>
</div>

