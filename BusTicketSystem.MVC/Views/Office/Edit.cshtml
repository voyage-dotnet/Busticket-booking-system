@model UpdateOfficeViewModel
@{
    ViewData["Title"] = "Edit Office";
    var officeId = (int)ViewBag.OfficeId;
    ViewData["Breadcrumb"] = $@"<a href='/Office'>My Offices</a><span class='sep'>›</span><a href='/Office/Details/{officeId}'>Office #{officeId}</a><span class='sep'>›</span><span class='active'>Edit</span>";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="vb-page-title mb-1"><i class="bi bi-pencil-fill"></i> Edit Office #@officeId</div>
        <p class="vb-page-subtitle">Update only the fields you want to change.</p>

        <form asp-controller="Office" asp-action="Edit" asp-route-id="@officeId" method="post" id="editOfficeForm">
            @Html.AntiForgeryToken()

            <div class="vb-section-title">Office Information</div>
            <div class="vb-card mb-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="vb-label">Office Email</div>
                        <input asp-for="OfficeMail" type="email" class="vb-input" placeholder="Leave blank to keep existing" />
                        <span asp-validation-for="OfficeMail" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Contact Person Name</div>
                        <input asp-for="OfficeContactPersonName" class="vb-input" placeholder="Leave blank to keep existing" />
                        <span asp-validation-for="OfficeContactPersonName" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Contact Number</div>
                        <input asp-for="OfficeContactNumber" type="tel" class="vb-input" placeholder="Leave blank to keep existing" />
                        <span asp-validation-for="OfficeContactNumber" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Address ID</div>
                        <input asp-for="OfficeAddressId" type="number" class="vb-input" placeholder="Leave blank to keep existing" min="1" />
                        <span asp-validation-for="OfficeAddressId" class="vb-validation-error"></span>
                    </div>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="vb-alert vb-alert-error mb-3"></div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-vb-primary">Save Changes <i class="bi bi-arrow-right ms-1"></i></button>
                <a asp-controller="Office" asp-action="Details" asp-route-id="@officeId" class="btn-vb-outline">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div style="position:sticky;top:72px;">
            <div class="vb-card mb-3">
                <div class="fw-700 mb-3">Save Changes</div>
                <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--vb-card-border);font-size:0.85rem;">
                    <span class="text-muted-vb">Office ID</span>
                    <span class="fw-600">#@officeId</span>
                </div>
                <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                    <span class="text-muted-vb">Status</span>
                    <span class="fw-600 text-green">Ready</span>
                </div>
                <hr class="vb-divider">
                <button form="editOfficeForm" type="submit" class="btn-vb-primary d-flex justify-content-center w-100">
                    Confirm &amp; Save <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
            <div class="vb-info-box">
                <i class="bi bi-info-circle"></i>
                <div style="font-size:0.78rem;">Only the fields you fill in will be updated. Others remain unchanged.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
