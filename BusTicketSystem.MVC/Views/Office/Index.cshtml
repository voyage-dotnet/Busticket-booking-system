@model OfficeListViewModel
@{
    ViewData["Title"] = "My Offices - VoyaBus";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold">Branch Offices</h1>
            <p class="vb-muted">Manage your regional offices and their resources.</p>
        </div>
        <a asp-controller="Office" asp-action="Create" class="btn btn-vb-dark px-4 py-2">
            <i class="bi bi-plus-lg me-2"></i> Add Office
        </a>
    </div>

    @if (!Model.Offices.Any())
    {
        <div class="vb-content-box text-center py-5 border-0 shadow-sm">
            <div class="opacity-25 mb-3"><i class="bi bi-building h1"></i></div>
            <h4 class="fw-bold">No offices registered</h4>
            <p class="vb-muted mb-4">Add your first branch office to start managing buses and drivers.</p>
            <a asp-controller="Office" asp-action="Create" class="btn btn-vb-dark rounded-pill px-4">Register Office</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var office in Model.Offices)
            {
                <div class="col-lg-6">
                    <div class="vb-content-box p-4 border-0 shadow-sm h-100">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="bg-light p-3 rounded-3"><i class="bi bi-building h4 mb-0 opacity-50"></i></div>
                                <div>
                                    <div class="h6 fw-bold mb-0">@office.OfficeContactPersonName</div>
                                    <div class="extra-small text-muted fw-bold text-uppercase letter-spacing-1">OFFICE #@office.OfficeId.ToString("D3")</div>
                                </div>
                            </div>
                            <span class="badge bg-success bg-opacity-10 text-success border-0 px-3 py-2 rounded-pill extra-small fw-bold">ACTIVE</span>
                        </div>

                        <div class="mb-4">
                            <div class="small text-muted mb-1"><i class="bi bi-envelope me-2"></i>@office.OfficeMail</div>
                            <div class="small text-muted mb-1"><i class="bi bi-telephone me-2"></i>@office.OfficeContactNumber</div>
                            <div class="small text-muted"><i class="bi bi-geo-alt me-2"></i>@office.FullAddress</div>
                        </div>

                        <div class="d-flex gap-2 pt-3 border-top">
                            <a asp-controller="Bus" asp-action="Index" asp-route-officeId="@office.OfficeId" class="btn btn-vb-dark btn-sm rounded-pill px-3 fw-bold small flex-grow-1">Manage Buses</a>
                            <a asp-controller="Driver" asp-action="Index" asp-route-officeId="@office.OfficeId" class="btn btn-outline-light border text-dark btn-sm rounded-pill px-3 fw-bold small flex-grow-1">Staff</a>
                            <a asp-controller="Office" asp-action="Edit" asp-route-id="@office.OfficeId" class="btn btn-outline-light border text-dark btn-sm rounded-pill px-3 fw-bold"><i class="bi bi-pencil-square"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .btn-vb-dark { background: #475569; color: white; border: 0; font-weight: 600; }
    .btn-vb-dark:hover { background: #334155; color: white; }
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05rem; }
</style>
