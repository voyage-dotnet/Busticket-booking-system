@model OfficeListViewModel
@{
    ViewData["Title"] = "My Offices";
    ViewData["Breadcrumb"] = @"<a href='/Agency/Profile'>My Profile</a><span class='sep'>›</span><span class='active'>My Offices</span>";
}

<div class="d-flex align-items-start justify-content-between mb-1">
    <div>
        <div class="vb-page-title"><i class="bi bi-diagram-3-fill"></i> My Offices</div>
        <p class="vb-page-subtitle">Branch offices registered under your agency.</p>
    </div>
    <a asp-controller="Office" asp-action="Create" class="btn-vb-primary mt-1">
        <i class="bi bi-plus-lg"></i> Add Office
    </a>
</div>

@if (!Model.Offices.Any())
{
    <div class="vb-card vb-empty">
        <div class="vb-empty-icon"><i class="bi bi-building-slash"></i></div>
        <div class="vb-empty-title">No offices yet</div>
        <div class="vb-empty-text">Add your first branch office to start managing buses and drivers.</div>
        <a asp-controller="Office" asp-action="Create" class="btn-vb-primary">
            <i class="bi bi-plus-lg"></i> Add First Office
        </a>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var office in Model.Offices)
        {
            <div class="vb-card" style="padding:1.25rem 1.5rem;">
                <div class="row align-items-center g-3">

                    <!-- Office Info (Trip row style) -->
                    <div class="col">
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <div class="vb-avatar" style="width:38px;height:38px;border-radius:8px;font-size:0.9rem;background:var(--vb-tag-bg);">
                                <i class="bi bi-building" style="color:var(--vb-navy);"></i>
                            </div>
                            <div>
                                <div class="fw-700" style="font-size:0.93rem;">
                                    @office.OfficeContactPersonName
                                    <span class="vb-tag vb-tag-navy ms-2">Office #@office.OfficeId</span>
                                </div>
                                <div class="text-muted-vb fs-sm">@office.OfficeMail</div>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-3 mt-2" style="font-size:0.82rem;color:var(--vb-text-mid);">
                            <span><i class="bi bi-telephone me-1"></i>@office.OfficeContactNumber</span>
                            @if (!string.IsNullOrWhiteSpace(office.FullAddress))
                            {
                                <span><i class="bi bi-geo-alt me-1"></i>@office.FullAddress</span>
                            }
                            <span class="text-green fw-600">
                                <i class="bi bi-check-circle-fill me-1"></i>Active
                            </span>
                        </div>
                    </div>

                    <!-- Right Actions -->
                    <div class="col-auto d-flex flex-column align-items-end gap-2">
                        <a asp-controller="Bus" asp-action="Index"
                           asp-route-officeId="@office.OfficeId"
                           class="btn-vb-primary" style="font-size:0.82rem;padding:0.45rem 1rem;">
                            <i class="bi bi-bus-front-fill"></i> Buses
                        </a>
                        <div class="d-flex gap-2">
                            <a asp-controller="Driver" asp-action="Index"
                               asp-route-officeId="@office.OfficeId"
                               class="btn-vb-outline" style="font-size:0.78rem;padding:0.35rem 0.75rem;">
                                <i class="bi bi-person-workspace"></i> Drivers
                            </a>
                            <a asp-controller="Office" asp-action="Edit"
                               asp-route-id="@office.OfficeId"
                               class="btn-vb-outline" style="font-size:0.78rem;padding:0.35rem 0.75rem;">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </div>
                        <a asp-controller="Office" asp-action="Details"
                           asp-route-id="@office.OfficeId" class="btn-vb-ghost fs-sm">
                            View details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
