@model CreateOfficeViewModel
@{
    ViewData["Title"] = "Add New Office";
    ViewData["Breadcrumb"] = @"<a href='/Office'>My Offices</a><span class='sep'>›</span><span class='active'>Add Office</span>";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="vb-page-title mb-1"><i class="bi bi-building-add"></i> Add New Office</div>
        <p class="vb-page-subtitle">Register a new branch office linked to your agency.</p>

        <form asp-controller="Office" asp-action="Create" method="post" id="createForm">
            @Html.AntiForgeryToken()

            <div class="vb-section-title">Office Information</div>
            <div class="vb-card mb-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="vb-label">Office Email</div>
                        <input asp-for="OfficeMail" type="email" class="vb-input"
                               placeholder="e.g. delhi@agency.com" />
                        <span asp-validation-for="OfficeMail" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Contact Person Name</div>
                        <input asp-for="OfficeContactPersonName" class="vb-input"
                               placeholder="e.g. Priya Mehta" />
                        <span asp-validation-for="OfficeContactPersonName" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Contact Number</div>
                        <input asp-for="OfficeContactNumber" type="tel" class="vb-input"
                               placeholder="e.g. +91 98765 43210" />
                        <span asp-validation-for="OfficeContactNumber" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Address ID</div>
                        <input asp-for="OfficeAddressId" type="number" class="vb-input"
                               placeholder="Enter existing Address ID" min="1" />
                        <span asp-validation-for="OfficeAddressId" class="vb-validation-error"></span>
                    </div>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="vb-alert vb-alert-error mb-3"></div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-vb-primary">
                    Create Office <i class="bi bi-arrow-right ms-1"></i>
                </button>
                <a asp-controller="Office" asp-action="Index" class="btn-vb-outline">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div style="position:sticky;top:72px;">
            <div class="vb-card mb-3">
                <div class="fw-700 mb-3">Office Setup</div>
                <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--vb-card-border);font-size:0.85rem;">
                    <span class="text-muted-vb">Fields Required</span>
                    <span class="fw-600">4</span>
                </div>
                <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                    <span class="text-muted-vb">Next Step</span>
                    <span class="fw-600">Add Buses</span>
                </div>
                <hr class="vb-divider">
                <button form="createForm" type="submit" class="btn-vb-primary d-flex justify-content-center w-100">
                    Create Office <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
            <div class="vb-info-box mb-2">
                <i class="bi bi-shield-lock-fill"></i>
                <div>
                    <div class="fw-600" style="font-size:0.8rem;color:var(--vb-navy);">Secure SSL</div>
                    <div style="font-size:0.78rem;">256-bit encryption active</div>
                </div>
            </div>
            <div class="vb-info-box">
                <i class="bi bi-info-circle"></i>
                <div style="font-size:0.78rem;">
                    The Address ID must already exist in the addresses table before creating the office.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
