@model BusTicketSystem.MVC.ViewModels.CustomerOverviewViewModel

@{
    ViewData["Title"] = "Customer Dashboard";
}

<div class="container mt-4">
    <h2>My Dashboard</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Trips Taken</h5>
                    <p class="card-text display-6">@Model.TotalTripsTaken</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Amount Spent</h5>
                    <p class="card-text display-6">$@Model.TotalAmountSpent</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Reviews Given</h5>
                    <p class="card-text display-6">@Model.TotalReviewsGiven</p>
                </div>
            </div>
        </div>
    </div>

    <h4>Recent Bookings</h4>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Route</th>
                <th>Date</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RecentBookings.Any())
            {
                foreach (var booking in Model.RecentBookings)
                {
                    <tr>
                        <td>@booking.BookingId</td>
                        <td>@booking.Route</td>
                        <td>@booking.Date.ToString("g")</td>
                        <td>
                            <span class="badge @(booking.Status == "Confirmed" ? "bg-success" : booking.Status == "Cancelled" ? "bg-danger" : "bg-warning")">
                                @booking.Status
                            </span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center">No recent bookings found.</td></tr>
            }
        </tbody>
    </table>
</div>
