@model BusTicketSystem.MVC.ViewModels.AgencyDashboardCompositeViewModel

@{
    ViewData["Title"] = "Agency Dashboard";
}

<div class="container mt-4">
    <h2>Agency Dashboard</h2>
    <hr />

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Trips</h5>
                    <p class="card-text display-6">@Model.Overview.TotalTrips</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Bookings</h5>
                    <p class="card-text display-6">@Model.Overview.TotalBookings</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Total Revenue</h5>
                    <p class="card-text display-6">$@Model.Overview.TotalRevenue</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Average Rating</h5>
                    <p class="card-text display-6">@Model.Overview.AverageRating <span style="font-size: 1rem;">(@Model.Overview.TotalReviews reviews)</span></p>
                </div>
            </div>
        </div>
    </div>

    <h4>Trip Stats</h4>
    <table class="table table-striped table-hover mb-4">
        <thead class="table-dark">
            <tr>
                <th>Route</th>
                <th>Departure Time</th>
                <th>Total Seats</th>
                <th>Booked Seats</th>
                <th>Occupancy %</th>
                <th>Revenue</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.TripStats.Any())
            {
                foreach (var trip in Model.TripStats)
                {
                    <tr>
                        <td>@trip.RouteName</td>
                        <td>@trip.DepartureTime.ToString("g")</td>
                        <td>@trip.TotalSeats</td>
                        <td>@trip.BookedSeats</td>
                        <td>@trip.OccupancyPercentage.ToString("0.##")%</td>
                        <td>$@trip.Revenue</td>
                        <td>
                            <span class="badge @(trip.Status == "Completed" ? "bg-secondary" : trip.Status == "Cancelled" ? "bg-danger" : "bg-success")">
                                @trip.Status
                            </span>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center">No trips found.</td></tr>
            }
        </tbody>
    </table>

    <h4>Top Routes</h4>
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>From City</th>
                <th>To City</th>
                <th>Booking Count</th>
                <th>Total Revenue</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.TopRoutes.Any())
            {
                foreach (var route in Model.TopRoutes)
                {
                    <tr>
                        <td>@route.FromCity</td>
                        <td>@route.ToCity</td>
                        <td>@route.BookingCount</td>
                        <td>$@route.TotalRevenue</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="4" class="text-center">No top routes found.</td></tr>
            }
        </tbody>
    </table>
</div>
