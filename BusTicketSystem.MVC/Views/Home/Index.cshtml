@{
    ViewData["Title"] = "Journey with Clarity - VoyaBus";
}

<div class="vb-hero-modern">
    <div class="vb-hero-overlay">
        <div class="container position-relative h-100 d-flex flex-column justify-content-center">
            <h1 class="vb-hero-title-modern">Journey with Clarity</h1>
            <p class="vb-hero-subtitle-modern">Premium transit connections across the continent. Simple, efficient, and always on time.</p>
            
            <div class="vb-search-card shadow-lg mt-5">
                <form asp-controller="Trips" asp-action="Index" method="get" class="row g-0 align-items-center">
                    <div class="col-lg-3 border-end">
                        <div class="vb-search-input-group px-4 py-3">
                            <label class="vb-search-label">ORIGIN</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt me-2 text-muted"></i>
                                <input type="text" name="from" class="vb-search-input-clean" placeholder="Where from?" required>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-3 border-end">
                        <div class="vb-search-input-group px-4 py-3">
                            <label class="vb-search-label">DESTINATION</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt-fill me-2 text-muted"></i>
                                <input type="text" name="to" class="vb-search-input-clean" placeholder="Where to?" required>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-2 border-end">
                        <div class="vb-search-input-group px-4 py-3">
                            <label class="vb-search-label">DATE</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-calendar3 me-2 text-muted"></i>
                                <input type="date" name="date" class="vb-search-input-clean" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-2 border-end">
                        <div class="vb-search-input-group px-4 py-3">
                            <label class="vb-search-label">PASSENGERS</label>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-people me-2 text-muted"></i>
                                <select class="vb-search-input-clean border-0 w-100">
                                    <option>1 Adult</option>
                                    <option>2 Adults</option>
                                    <option>3 Adults</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-2 p-3">
                        <button type="submit" class="vb-btn-search-modern w-100 h-100 py-3">Find My Trip</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .vb-hero-modern { height: 500px; background: url('https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&q=80&w=2000') center/cover; position: relative; }
    .vb-hero-overlay { position: absolute; inset: 0; background: rgba(15, 23, 42, 0.6); }
    .vb-hero-title-modern { font-size: 3.5rem; font-weight: 700; color: white; margin-bottom: 1rem; }
    .vb-hero-subtitle-modern { color: rgba(255,255,255,0.8); font-size: 1.1rem; max-width: 600px; }
    .vb-search-card { background: white; border-radius: 12px; overflow: hidden; }
    .vb-search-input-group { background: white; transition: background 0.2s; }
    .vb-search-input-group:hover { background: #f8fafc; }
    .vb-search-label { font-size: 0.65rem; font-weight: 700; color: #64748b; letter-spacing: 0.05rem; display: block; margin-bottom: 4px; }
    .vb-search-input-clean { border: 0; padding: 0; font-size: 1rem; font-weight: 500; color: #0f172a; width: 100%; outline: none; background: transparent; }
    .vb-btn-search-modern { background: #475569; color: white; border: 0; font-weight: 600; transition: background 0.2s; border-radius: 8px; }
    .vb-btn-search-modern:hover { background: #334155; }
    .vb-trip-recent-card { background: white; border: 1px solid #e2e8f0; border-radius: 12px; }
    .vb-live-network-card { background: #e2e8f0; border-radius: 12px; display: flex; flex-direction: column; }
    .vb-stats-box { background: white; padding: 20px; border-radius: 8px; }
    .letter-spacing-1 { letter-spacing: 0.1rem; }
</style>
