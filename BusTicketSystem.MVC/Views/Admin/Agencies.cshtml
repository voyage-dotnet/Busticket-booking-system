@model List<BusTicketSystem.MVC.ViewModels.AdminAgencyStatsViewModel>
@{
    ViewData["Title"] = "Agency Performance";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <nav class="small mb-2">
                <a asp-action="Dashboard" class="text-decoration-none text-muted">Admin Dashboard</a>
                <span class="mx-2 text-muted">/</span>
                <span class="text-dark">Agencies</span>
            </nav>
            <h1 class="h2 fw-bold">Agency Performance</h1>
        </div>
    </div>

    <div class="vb-content-box p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Agency Name</th>
                        <th class="py-3 border-0">Fleet Size</th>
                        <th class="py-3 border-0">Total Trips</th>
                        <th class="py-3 border-0 text-end">Total Revenue</th>
                        <th class="pe-4 py-3 border-0 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agency in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@agency.Name</div>
                                <div class="small text-muted">ID: @agency.AgencyId</div>
                            </td>
                            <td>@agency.TotalBuses Buses</td>
                            <td>@agency.TotalTrips Trips</td>
                            <td class="text-end fw-bold text-success">$@agency.TotalRevenue.ToString("N2")</td>
                            <td class="pe-4 text-end">
                                <button class="btn btn-outline-dark btn-sm rounded-pill px-3">View Details</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
