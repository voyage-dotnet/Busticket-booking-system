@model BusTicketSystem.MVC.ViewModels.UserDetailViewModel
@{
    ViewData["Title"] = "Manage User";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="mb-4">
                <a asp-action="Users" class="text-decoration-none text-muted small">
                    <i class="bi bi-arrow-left me-1"></i> Back to Users
                </a>
            </div>

            <div class="vb-content-box p-4">
                <h2 class="h3 fw-bold mb-4">Manage User Access</h2>
                
                <div class="mb-5">
                    <div class="text-muted small fw-bold mb-1">ACCOUNT EMAIL</div>
                    <div class="h5">@Model.Email</div>
                </div>

                <div class="mb-5">
                    <div class="text-muted small fw-bold mb-1">CURRENT ROLE</div>
                    <span class="badge @(Model.Role == "Admin" ? "bg-danger" : Model.Role == "Agency" ? "bg-primary" : "bg-success") bg-opacity-10 @(Model.Role == "Admin" ? "text-danger" : Model.Role == "Agency" ? "text-primary" : "text-success") px-3 py-2 rounded-pill h6 mb-0">
                        @Model.Role
                    </span>
                </div>

                <hr class="my-5 opacity-10">

                <form asp-action="UpdateRole" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="UserId" value="@Model.UserId" />
                    
                    <label class="vb-form-label mb-3">ASSIGN NEW ROLE</label>
                    <select name="NewRole" class="vb-form-control mb-4">
                        <option value="Customer" selected="@(Model.Role == "Customer")">Customer</option>
                        <option value="Agency" selected="@(Model.Role == "Agency")">Agency</option>
                        <option value="Admin" selected="@(Model.Role == "Admin")">Admin</option>
                    </select>

                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-3">
                        Update Role Access
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
