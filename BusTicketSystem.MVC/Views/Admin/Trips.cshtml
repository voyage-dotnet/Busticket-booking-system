@model List<BusTicketSystem.MVC.ViewModels.AdminTripViewModel>
@{
    ViewData["Title"] = "Trip Monitoring";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <nav class="small mb-2">
                <a asp-action="Dashboard" class="text-decoration-none text-muted">Admin Dashboard</a>
                <span class="mx-2 text-muted">/</span>
                <span class="text-dark">Trips</span>
            </nav>
            <h1 class="h2 fw-bold">Trip Monitoring</h1>
        </div>
    </div>

    <div class="vb-content-box p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Route / Agency</th>
                        <th class="py-3 border-0">Departure</th>
                        <th class="py-3 border-0">Occupancy</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="pe-4 py-3 border-0 text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trip in Model)
                    {
                        var occupancyPct = (double)trip.Occupancy / trip.TotalSeats * 100;
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@trip.RouteName</div>
                                <div class="small text-muted">Operator: @trip.AgencyName</div>
                            </td>
                            <td>@trip.DepartureTime.ToString("MMM dd, HH:mm tt")</td>
                            <td style="min-width: 150px;">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar @(occupancyPct > 80 ? "bg-success" : occupancyPct > 40 ? "bg-primary" : "bg-warning")" 
                                             style="width: @occupancyPct%"></div>
                                    </div>
                                    <span class="small fw-bold">@trip.Occupancy / @trip.TotalSeats</span>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-dark border px-3 py-2 rounded-pill extra-small">
                                    @trip.Status
                                </span>
                            </td>
                            <td class="pe-4 text-end">
                                <button class="btn btn-outline-dark btn-sm rounded-pill px-3">Audit</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
