@model List<BusTicketSystem.MVC.ViewModels.AdminBookingViewModel>
@{
    ViewData["Title"] = "Global Bookings";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <nav class="small mb-2">
                <a asp-action="Dashboard" class="text-decoration-none text-muted">Admin Dashboard</a>
                <span class="mx-2 text-muted">/</span>
                <span class="text-dark">Bookings</span>
            </nav>
            <h1 class="h2 fw-bold">Global Bookings</h1>
        </div>
    </div>

    <div class="vb-content-box p-0 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Booking ID</th>
                        <th class="py-3 border-0">Customer</th>
                        <th class="py-3 border-0">Route</th>
                        <th class="py-3 border-0">Date</th>
                        <th class="py-3 border-0">Status</th>
                        <th class="pe-4 py-3 border-0 text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">#@booking.BookingId</td>
                            <td>@booking.CustomerName</td>
                            <td>@booking.RouteName</td>
                            <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="badge @(booking.Status == "Confirmed" ? "bg-success" : booking.Status == "Pending" ? "bg-warning text-dark" : "bg-danger") bg-opacity-10 @(booking.Status == "Confirmed" ? "text-success" : booking.Status == "Pending" ? "text-warning" : "text-danger") border-0 px-3 py-2 rounded-pill small">
                                    @booking.Status
                                </span>
                            </td>
                            <td class="pe-4 text-end fw-bold">$@booking.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
