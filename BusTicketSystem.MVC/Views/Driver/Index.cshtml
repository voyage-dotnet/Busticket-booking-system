@model DriverListViewModel
@{
    ViewData["Title"] = "Drivers Management - VoyaBus";
    var officeName = ViewBag.OfficeName as string ?? $"Office #{Model.OfficeId}";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold">Drivers Staff</h1>
            <p class="vb-muted">Personnel assigned to @officeName.</p>
        </div>
        <a asp-controller="Driver" asp-action="Create" class="btn btn-vb-dark px-4 py-2">
            <i class="bi bi-person-plus me-2"></i> Add Driver
        </a>
    </div>

    @if (!Model.Drivers.Any())
    {
        <div class="vb-content-box text-center py-5 border-0 shadow-sm">
            <div class="opacity-25 mb-3"><i class="bi bi-person-badge h1"></i></div>
            <h4 class="fw-bold">No drivers assigned</h4>
            <p class="vb-muted mb-4">Add your first driver to this office to assign them to trips.</p>
            <a asp-controller="Driver" asp-action="Create" class="btn btn-vb-dark rounded-pill px-4">Add Driver</a>
        </div>
    }
    else
    {
        <div class="row g-5">
            <div class="col-lg-8">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <div class="text-muted small fw-bold">
                        <span class="text-dark">@Model.Drivers.Count</span> staff members
                    </div>
                </div>

                <div class="d-flex flex-column gap-3">
                    @foreach (var driver in Model.Drivers)
                    {
                        <div class="vb-content-box p-4 border-0 shadow-sm">
                            <div class="row align-items-center g-3">
                                <div class="col-auto">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold h5 mb-0" style="width: 48px; height: 48px;">
                                        @driver.Name.Substring(0, 1).ToUpper()
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="h6 fw-bold mb-1">@driver.Name</div>
                                    <div class="d-flex flex-wrap gap-4 align-items-center">
                                        <div class="small fw-bold opacity-50 mono text-uppercase letter-spacing-1">LIC: @driver.LicenseNumber</div>
                                        <div class="small text-muted"><i class="bi bi-telephone me-2"></i>@driver.Phone</div>
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <a asp-controller="Driver" asp-action="Edit" asp-route-id="@driver.DriverId" asp-route-officeId="@driver.OfficeId" class="btn btn-outline-light border text-dark btn-sm rounded-pill px-3 fw-bold small">Edit Staff</a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="vb-selection-summary-card p-4 text-white mb-4 shadow-lg sticky-top" style="top: 100px; background: #334155;">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h6 class="fw-bold mb-0">Staff Summary</h6>
                        <i class="bi bi-person-fill-gear h4 mb-0 opacity-50"></i>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75 small">Total Drivers</span>
                        <span class="fw-bold">@Model.Drivers.Count</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="opacity-75 small">Office ID</span>
                        <span class="fw-bold">#@Model.OfficeId.ToString("D3")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4 pb-4 border-bottom border-white border-opacity-25">
                        <span class="opacity-75 small">Status</span>
                        <span class="fw-bold text-success">Active</span>
                    </div>

                    <a asp-controller="Driver" asp-action="Create" class="btn btn-white-modern w-100 py-3 fw-bold rounded-3 text-center text-decoration-none">Add New Driver</a>
                    <div class="text-center extra-small opacity-50 mt-4 text-uppercase">VoyaBus Staff Management</div>
                </div>

                <div class="vb-notice-card p-3 rounded-3 d-flex gap-3 align-items-start border">
                    <i class="bi bi-info-circle text-muted h5 mb-0"></i>
                    <div class="small text-muted">
                        Drivers can be reassigned up to 2 hours before departure for a small convenience fee.
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .btn-vb-dark { background: #475569; color: white; border: 0; font-weight: 600; }
    .btn-vb-dark:hover { background: #334155; color: white; }
    .btn-white-modern { background: white; color: #334155; border: 0; }
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05rem; }
    .mono { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }
</style>
