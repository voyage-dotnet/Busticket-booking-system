@model DriverListViewModel
@{
    ViewData["Title"] = "Drivers";
    var officeName = ViewBag.OfficeName as string ?? $"Office #{Model.OfficeId}";
    ViewData["Breadcrumb"] = $@"<a href='/Office'>My Offices</a><span class='sep'>›</span><a href='/Office/Details/{Model.OfficeId}'>{officeName}</a><span class='sep'>›</span><span class='active'>Drivers</span>";
}

<div class="d-flex align-items-start justify-content-between mb-1">
    <div>
        <div class="vb-page-title"><i class="bi bi-person-workspace"></i> Drivers</div>
        <p class="vb-page-subtitle">Staff assigned to @officeName.</p>
    </div>
    <a asp-controller="Driver" asp-action="Create" class="btn-vb-primary mt-1">
        <i class="bi bi-person-plus-fill"></i> Add Driver
    </a>
</div>

@if (!Model.Drivers.Any())
{
    <div class="vb-card vb-empty">
        <div class="vb-empty-icon"><i class="bi bi-person-x"></i></div>
        <div class="vb-empty-title">No drivers assigned</div>
        <div class="vb-empty-text">Add your first driver to this office to assign them to trips.</div>
        <a asp-controller="Driver" asp-action="Create" class="btn-vb-primary"><i class="bi bi-person-plus-fill"></i> Add Driver</a>
    </div>
}
else
{
    <!-- Seat-selection style: Selection Summary box -->
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <p class="mb-0 text-muted-vb" style="font-size:0.85rem;">
                    <strong style="color:var(--vb-text);">@Model.Drivers.Count</strong> drivers at this office
                </p>
            </div>

            <div class="d-flex flex-column gap-3">
                @foreach (var driver in Model.Drivers)
                {
                    <div class="vb-card" style="padding:1.1rem 1.5rem;">
                        <div class="row align-items-center g-2">
                            <div class="col-auto">
                                <div class="vb-avatar" style="width:42px;height:42px;font-size:1rem;border-radius:50%;">
                                    @driver.Name.Substring(0,1).ToUpper()
                                </div>
                            </div>
                            <div class="col">
                                <div class="fw-700" style="font-size:0.92rem;">@driver.Name</div>
                                <div class="d-flex flex-wrap gap-3 text-muted-vb" style="font-size:0.8rem;">
                                    <span style="font-family:monospace;color:var(--vb-accent);">@driver.LicenseNumber</span>
                                    <span><i class="bi bi-telephone me-1"></i>@driver.Phone</span>
                                    <span class="vb-tag vb-tag-gray">Driver #@driver.DriverId</span>
                                </div>
                            </div>
                            <div class="col-auto">
                                <a asp-controller="Driver" asp-action="Edit"
                                   asp-route-id="@driver.DriverId"
                                   asp-route-officeId="@Model.OfficeId"
                                   class="btn-vb-outline" style="font-size:0.8rem;padding:0.4rem 0.85rem;">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Selection Summary style box -->
        <div class="col-lg-4">
            <div style="position:sticky;top:72px;">
                <div class="vb-card" style="background:var(--vb-navy);border-color:var(--vb-navy);color:#fff;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="fw-700" style="font-size:0.95rem;">Staff Summary</div>
                        <i class="bi bi-person-fill-gear"></i>
                    </div>

                    <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid rgba(255,255,255,0.15);font-size:0.85rem;">
                        <span style="opacity:.7;">Total Drivers</span>
                        <span class="fw-700">@Model.Drivers.Count</span>
                    </div>
                    <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid rgba(255,255,255,0.15);font-size:0.85rem;">
                        <span style="opacity:.7;">Office ID</span>
                        <span class="fw-700">#@Model.OfficeId</span>
                    </div>
                    <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                        <span style="opacity:.7;">Status</span>
                        <span class="fw-700" style="color:#6ee7b7;">Active</span>
                    </div>

                    <a asp-controller="Driver" asp-action="Create"
                       class="d-flex justify-content-center w-100 mt-3"
                       style="background:#fff;color:var(--vb-navy);border-radius:6px;font-weight:700;font-size:0.88rem;padding:0.6rem;text-decoration:none;transition:opacity .15s;">
                        Add Driver
                    </a>
                    <p class="text-center mt-2" style="font-size:0.72rem;opacity:.6;">
                        PRICES INCLUDE ALL TRANSIT TAXES
                    </p>
                </div>

                <div class="vb-info-box mt-3">
                    <i class="bi bi-info-circle"></i>
                    <div style="font-size:0.78rem;">
                        Drivers can be reassigned up to 2 hours before departure for a small convenience fee.
                    </div>
                </div>
            </div>
        </div>
    </div>
}
