@model UpdateDriverViewModel
@{
    ViewData["Title"] = "Edit Driver";
    var driverId = (int)ViewBag.DriverId;
    var officeId = (int)ViewBag.OfficeId;
    ViewData["Breadcrumb"] = $@"<a href='/Driver/Index?officeId={officeId}'>Drivers</a><span class='sep'>›</span><span class='active'>Edit Driver #{driverId}</span>";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="vb-page-title mb-1"><i class="bi bi-person-gear"></i> Update Driver #@driverId</div>
        <p class="vb-page-subtitle">Fill only the fields you want to change.</p>

        <form asp-controller="Driver" asp-action="Edit" asp-route-id="@driverId" asp-route-officeId="@officeId" method="post" id="editDriverForm">
            @Html.AntiForgeryToken()
            <div class="vb-section-title">Driver Information</div>
            <div class="vb-card mb-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="vb-label">Full Name</div>
                        <input asp-for="Name" class="vb-input" placeholder="Leave blank to keep existing" />
                        <span asp-validation-for="Name" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">License Number</div>
                        <input asp-for="LicenseNumber" class="vb-input" placeholder="Leave blank to keep existing" style="text-transform:uppercase;" />
                        <span asp-validation-for="LicenseNumber" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Phone Number</div>
                        <input asp-for="Phone" type="tel" class="vb-input" placeholder="Leave blank to keep existing" />
                        <span asp-validation-for="Phone" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Assigned Office ID</div>
                        <input asp-for="OfficeId" type="number" class="vb-input" placeholder="Leave blank to keep existing" min="1" />
                        <span asp-validation-for="OfficeId" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Address ID</div>
                        <input asp-for="AddressId" type="number" class="vb-input" placeholder="Leave blank to keep existing" min="1" />
                        <span asp-validation-for="AddressId" class="vb-validation-error"></span>
                    </div>
                </div>
            </div>
            <div asp-validation-summary="ModelOnly" class="vb-alert vb-alert-error mb-3"></div>
            <div class="d-flex gap-3">
                <button type="submit" class="btn-vb-primary">Save Changes <i class="bi bi-arrow-right ms-1"></i></button>
                <a asp-controller="Driver" asp-action="Index" asp-route-officeId="@officeId" class="btn-vb-outline">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div style="position:sticky;top:72px;">
            <div class="vb-card" style="background:var(--vb-navy);border-color:var(--vb-navy);color:#fff;">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div class="fw-700" style="font-size:0.95rem;">Selection Summary</div>
                    <i class="bi bi-person-fill-gear"></i>
                </div>
                <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid rgba(255,255,255,0.15);font-size:0.85rem;">
                    <span style="opacity:.7;">Driver ID</span>
                    <span class="fw-700">#@driverId</span>
                </div>
                <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                    <span style="opacity:.7;">Office</span>
                    <span class="fw-700">#@officeId</span>
                </div>
                <button form="editDriverForm" type="submit"
                        class="d-flex justify-content-center w-100 mt-3"
                        style="background:#fff;color:var(--vb-navy);border:none;border-radius:6px;font-weight:700;font-size:0.88rem;padding:0.6rem;cursor:pointer;">
                    Confirm Update
                </button>
                <p class="text-center mt-2" style="font-size:0.72rem;opacity:.6;">PRICES INCLUDE ALL TRANSIT TAXES</p>
            </div>
            <div class="vb-info-box mt-3">
                <i class="bi bi-info-circle"></i>
                <div style="font-size:0.78rem;">Only filled fields will be updated. Blank fields are ignored.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
