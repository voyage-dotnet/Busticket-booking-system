@model BusTicketSystem.MVC.ViewModels.RouteViewModel
@{
    ViewData["Title"] = "Route Details";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav class="vb-breadcrumb mb-4">
                <a asp-action="Index" class="vb-breadcrumb-item">Routes</a>
                <span class="vb-breadcrumb-sep"><i class="bi bi-chevron-right"></i></span>
                <span class="vb-breadcrumb-item active">Details</span>
            </nav>

            <div class="vb-content-box p-0 overflow-hidden">
                <div class="vb-card-dark p-4 rounded-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="vb-badge vb-badge-route mb-2">ROUTE ID: #@Model.RouteId</div>
                            <h2 class="h3 mb-0 fw-bold">@Model.FromCity <i class="bi bi-arrow-right mx-2 text-white-50"></i> @Model.ToCity</h2>
                        </div>
                        <i class="bi bi-map h1 mb-0 opacity-25"></i>
                    </div>
                </div>

                <div class="p-4">
                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label class="vb-form-label">Source City</label>
                                <div class="h5 fw-bold">@Model.FromCity</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label class="vb-form-label">Destination City</label>
                                <div class="h5 fw-bold">@Model.ToCity</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label class="vb-form-label">Distance</label>
                                <div class="h5 fw-bold">@Model.Distance km</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label class="vb-form-label">Estimated Duration</label>
                                <div class="h5 fw-bold">@Model.EstimatedDuration Hours</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-3 pt-3 border-top">
                        <a asp-action="Edit" asp-route-id="@Model.RouteId" class="vb-btn-primary px-5">Edit Route</a>
                        <a asp-action="Index" class="vb-btn-ghost">Back to List</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
