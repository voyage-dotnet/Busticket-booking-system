@model List<BusTicketSystem.MVC.ViewModels.RouteViewModel>
@{
    ViewData["Title"] = "Manage Routes";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="h2 fw-bold mb-1">Route Network</h1>
            <p class="vb-text-muted mb-0">Define and manage travel paths across the country. Total: <strong>@Model.Count routes</strong></p>
        </div>
        <a asp-action="Create" class="vb-btn-primary">
            <i class="bi bi-map"></i> Define New Route
        </a>
    </div>

    <div class="row g-4">
        @if (Model.Count == 0)
        {
            <div class="col-12 text-center py-5">
                <div class="vb-card p-5">
                    <i class="bi bi-signpost-2 h1 text-muted opacity-25 mb-3 d-block"></i>
                    <h5 class="fw-bold">No routes defined yet</h5>
                    <p class="vb-text-muted small">Add your first travel route to start scheduling trips.</p>
                    <a asp-action="Create" class="vb-btn-primary mt-2">Define First Route</a>
                </div>
            </div>
        }
        @foreach (var route in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="vb-card h-100 shadow-sm border-0 position-relative overflow-hidden">
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="vb-badge vb-badge-verified">Route #@route.RouteId</span>
                            <div class="dropdown">
                                <button class="btn btn-sm vb-btn-ghost p-1" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu border-0 shadow-lg p-2">
                                    <li><a class="dropdown-item small rounded-2" asp-action="Edit" asp-route-id="@route.RouteId">Edit Route</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-action="Delete" asp-route-id="@route.RouteId" method="post" onsubmit="return confirm('Are you sure you want to delete this route?');">
                                            <button type="submit" class="dropdown-item small rounded-2 text-danger">Delete Route</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="fw-bold h5 mb-0">@route.FromCity</div>
                            <i class="bi bi-arrow-right text-primary h5 mb-0"></i>
                            <div class="fw-bold h5 mb-0">@route.ToCity</div>
                        </div>

                        <div class="d-flex gap-4">
                            <div>
                                <div class="vb-text-muted extra-small text-uppercase fw-bold">Break Points</div>
                                <div class="fw-bold small">@(string.IsNullOrEmpty(route.BreakPoints) ? "Direct" : route.BreakPoints)</div>
                            </div>
                            <div>
                                <div class="vb-text-muted extra-small text-uppercase fw-bold">Est. Duration</div>
                                <div class="fw-bold">@(route.EstimatedDurationMinutes / 60)h @(route.EstimatedDurationMinutes % 60)m</div>
                            </div>
                        </div>
                    </div>
                    <div class="bg-light p-3 border-top d-flex justify-content-between align-items-center">
                        <span class="small vb-text-secondary"><i class="bi bi-geo-alt me-1"></i> @route.FromCity → @route.ToCity</span>
                        <a asp-controller="Trips" asp-action="Index" asp-route-from="@route.FromCity" asp-route-to="@route.ToCity" class="vb-btn-ghost p-0 h-auto small fw-bold">View Trips</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05em; }
</style>
