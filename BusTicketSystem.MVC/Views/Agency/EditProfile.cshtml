@model UpdateAgencyViewModel
@{
    ViewData["Title"] = "Edit Agency Profile";
    ViewData["Breadcrumb"] = @"<a href='/Agency/Profile'>My Profile</a><span class='sep'>›</span><span class='active'>Edit Profile</span>";
}

<div class="row g-4">

    
    <div class="col-lg-8">

        <div class="vb-page-title mb-1">
            <i class="bi bi-pencil-fill"></i>
            Edit Agency Profile
        </div>
        <p class="vb-page-subtitle">Update your agency's contact information below.</p>

        <form asp-controller="Agency" asp-action="EditProfile" method="post" id="editForm">
            @Html.AntiForgeryToken()

            <div class="vb-section-title">Agency Information</div>
            <div class="vb-card mb-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="vb-form-group mb-0">
                            <label asp-for="Name" class="vb-label"></label>
                            <input asp-for="Name" class="vb-input" placeholder="e.g. SkyLine Travels" />
                            <span asp-validation-for="Name" class="vb-validation-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-form-group mb-0">
                            <label asp-for="ContactPersonName" class="vb-label"></label>
                            <input asp-for="ContactPersonName" class="vb-input" placeholder="e.g. Rahul Sharma" />
                            <span asp-validation-for="ContactPersonName" class="vb-validation-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-form-group mb-0">
                            <label asp-for="Email" class="vb-label"></label>
                            <input asp-for="Email" type="email" class="vb-input" placeholder="contact@agency.com" />
                            <span asp-validation-for="Email" class="vb-validation-error"></span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-form-group mb-0">
                            <label asp-for="Phone" class="vb-label"></label>
                            <input asp-for="Phone" type="tel" class="vb-input" placeholder="+91 98765 43210" />
                            <span asp-validation-for="Phone" class="vb-validation-error"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="vb-alert vb-alert-error mb-3" style="display:@(ViewData.ModelState.IsValid ? "none" : "flex");"></div>

            <div class="d-flex gap-3">
                <button type="submit" class="btn-vb-primary">
                    Confirm &amp; Save &nbsp;<i class="bi bi-arrow-right"></i>
                </button>
                <a asp-controller="Agency" asp-action="Profile" class="btn-vb-outline">
                    Cancel
                </a>
            </div>
        </form>
    </div>

    
    <div class="col-lg-4">
        <div style="position:sticky;top:72px;">
            <div class="vb-card mb-3">
                <div class="fw-700 mb-3" style="font-size:1rem;">Save Changes</div>

                <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--vb-card-border);font-size:0.85rem;">
                    <span class="text-muted-vb">Fields Updated</span>
                    <span class="fw-600" id="fieldsCount">0</span>
                </div>
                <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                    <span class="text-muted-vb">Status</span>
                    <span class="fw-600 text-green">Ready to Save</span>
                </div>

                <hr class="vb-divider">

                <button type="submit" form="editForm" class="btn-vb-primary d-flex justify-content-center w-100 mb-2">
                    Confirm &amp; Save &nbsp;<i class="bi bi-arrow-right"></i>
                </button>
                <p class="text-center text-muted-vb" style="font-size:0.72rem;">
                    By saving, you agree to our Terms of Service.
                </p>
            </div>

            <div class="vb-info-box mb-2">
                <i class="bi bi-shield-lock-fill"></i>
                <div>
                    <div class="fw-600" style="font-size:0.8rem;color:var(--vb-navy);">Secure SSL</div>
                    <div style="font-size:0.78rem;">256-bit encryption active</div>
                </div>
            </div>

            <div class="vb-info-box">
                <i class="bi bi-info-circle"></i>
                <div style="font-size:0.78rem;">
                    Email changes require re-verification before taking effect.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        
        const inputs = document.querySelectorAll('#editForm input');
        const counter = document.getElementById('fieldsCount');
        function countFields() {
            counter.textContent = [...inputs].filter(i => i.value.trim()).length;
        }
        inputs.forEach(i => i.addEventListener('input', countFields));
    </script>
}
