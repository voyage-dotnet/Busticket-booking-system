@model UpdateBusViewModel
@{
    ViewData["Title"] = "Edit Bus";
    var busId = (int)ViewBag.BusId;
    var officeId = (int)ViewBag.OfficeId;
    ViewData["Breadcrumb"] = $@"<a href='/Bus/Index/{officeId}'>Fleet</a><span class='sep'>›</span><span class='active'>Edit Bus #{busId}</span>";
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="vb-page-title mb-1"><i class="bi bi-bus-front"></i> Update Bus #@busId</div>
        <p class="vb-page-subtitle">Fill only fields you want to change.</p>

        <form asp-controller="Bus" asp-action="Edit" asp-route-id="@busId" asp-route-officeId="@officeId" method="post" id="editBusForm">
            @Html.AntiForgeryToken()
            <div class="vb-section-title">Bus Information</div>
            <div class="vb-card mb-3">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="vb-label">Registration Number</div>
                        <input asp-for="RegistrationNumber" class="vb-input" placeholder="Leave blank to keep existing" style="text-transform:uppercase;" />
                        <span asp-validation-for="RegistrationNumber" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Bus Type</div>
                        <select asp-for="Type" class="vb-input">
                            <option value="">— Keep existing —</option>
                            <option value="Sleeper">Sleeper</option>
                            <option value="Semi-Sleeper">Semi-Sleeper</option>
                            <option value="Seater">Seater</option>
                            <option value="AC Sleeper">AC Sleeper</option>
                            <option value="AC Seater">AC Seater</option>
                            <option value="Volvo AC">Volvo AC</option>
                        </select>
                        <span asp-validation-for="Type" class="vb-validation-error"></span>
                    </div>
                    <div class="col-sm-6">
                        <div class="vb-label">Seat Capacity</div>
                        <input asp-for="Capacity" type="number" class="vb-input" placeholder="Leave blank to keep existing" min="1" max="100" />
                        <span asp-validation-for="Capacity" class="vb-validation-error"></span>
                    </div>
                </div>
            </div>
            <div asp-validation-summary="ModelOnly" class="vb-alert vb-alert-error mb-3"></div>
            <div class="d-flex gap-3">
                <button type="submit" class="btn-vb-primary">Save Changes <i class="bi bi-arrow-right ms-1"></i></button>
                <a asp-controller="Bus" asp-action="Index" asp-route-officeId="@officeId" class="btn-vb-outline">Cancel</a>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div style="position:sticky;top:72px;">
            <div class="vb-card mb-3">
                <div class="fw-700 mb-3">Update Summary</div>
                <div class="d-flex justify-content-between py-2" style="border-bottom:1px solid var(--vb-card-border);font-size:0.85rem;">
                    <span class="text-muted-vb">Bus ID</span><span class="fw-600">#@busId</span>
                </div>
                <div class="d-flex justify-content-between py-2" style="font-size:0.85rem;">
                    <span class="text-muted-vb">Office</span><span class="fw-600">#@officeId</span>
                </div>
                <hr class="vb-divider">
                <button form="editBusForm" type="submit" class="btn-vb-primary d-flex justify-content-center w-100">
                    Confirm Update <i class="bi bi-arrow-right ms-2"></i>
                </button>
            </div>
            <div class="vb-info-box">
                <i class="bi bi-info-circle"></i>
                <div style="font-size:0.78rem;">Only filled fields will be updated. Blanks are ignored.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
