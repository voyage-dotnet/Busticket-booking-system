@model BusListViewModel
@{
    ViewData["Title"] = "Bus Fleet Management - VoyaBus";
    var officeName = ViewBag.OfficeName as string ?? $"Office #{Model.OfficeId}";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold">Bus Fleet</h1>
            <p class="vb-muted">Registered vehicles for @officeName.</p>
        </div>
        <a asp-controller="Bus" asp-action="Create" class="btn btn-vb-dark px-4 py-2">
            <i class="bi bi-plus-lg me-2"></i> Register Bus
        </a>
    </div>

    @if (!Model.Buses.Any())
    {
        <div class="vb-content-box text-center py-5 border-0 shadow-sm">
            <div class="opacity-25 mb-3"><i class="bi bi-bus-front h1"></i></div>
            <h4 class="fw-bold">No buses registered</h4>
            <p class="vb-muted mb-4">Register your first bus to assign it to trips.</p>
            <a asp-controller="Bus" asp-action="Create" class="btn btn-vb-dark rounded-pill px-4">Register Bus</a>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div class="text-muted small fw-bold">
                <span class="text-dark">@Model.Buses.Count</span> vehicles total
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="extra-small text-muted fw-bold">SORT BY:</span>
                <select class="form-select form-select-sm border-0 bg-transparent fw-bold p-0" style="width: auto;">
                    <option>Registration No.</option>
                    <option>Capacity</option>
                </select>
            </div>
        </div>

        <div class="row g-4">
            @foreach (var bus in Model.Buses)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="vb-content-box p-4 border-0 shadow-sm h-100 position-relative overflow-hidden">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div class="bg-light p-3 rounded-3"><i class="bi bi-bus-front h4 mb-0 opacity-50"></i></div>
                            <span class="badge bg-primary bg-opacity-10 text-primary border-0 px-3 py-2 rounded-pill extra-small fw-bold">@bus.Type.ToUpper()</span>
                        </div>
                        <div class="h5 fw-bold mb-1 mono letter-spacing-1">@bus.RegistrationNumber</div>
                        <div class="extra-small text-muted fw-bold mb-4">BUS ID #@bus.BusId.ToString("D3")</div>
                        
                        <div class="d-flex gap-3 mb-5 border-top pt-3">
                            <div class="d-flex align-items-center gap-2 small">
                                <i class="bi bi-people text-muted"></i>
                                <span class="fw-bold">@bus.Capacity Seats</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 small">
                                <i class="bi bi-wifi text-success"></i>
                                <span class="fw-bold text-success">Wi-Fi</span>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <a asp-controller="Bus" asp-action="Edit" asp-route-id="@bus.BusId" asp-route-officeId="@bus.OfficeId" class="btn btn-vb-dark btn-sm rounded-pill px-4 fw-bold flex-grow-1">Edit Details</a>
                            <a href="#" class="btn btn-outline-light border text-dark btn-sm rounded-pill px-3 fw-bold"><i class="bi bi-gear"></i></a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .btn-vb-dark { background: #475569; color: white; border: 0; font-weight: 600; }
    .btn-vb-dark:hover { background: #334155; color: white; }
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05rem; }
    .letter-spacing-1 { letter-spacing: 0.1rem; }
    .mono { font-family: 'JetBrains Mono', 'Roboto Mono', monospace; }
</style>
