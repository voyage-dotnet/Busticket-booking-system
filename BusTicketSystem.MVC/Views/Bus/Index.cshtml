@model BusListViewModel
@{
    ViewData["Title"] = "Bus Fleet";
    var officeName = ViewBag.OfficeName as string ?? $"Office #{Model.OfficeId}";
    ViewData["Breadcrumb"] = $@"<a href='/Office'>My Offices</a><span class='sep'>›</span><a href='/Office/Details/{Model.OfficeId}'>{officeName}</a><span class='sep'>›</span><span class='active'>Buses</span>";
}

<div class="d-flex align-items-start justify-content-between mb-1">
    <div>
        <div class="vb-page-title"><i class="bi bi-bus-front-fill"></i> Bus Fleet</div>
        <p class="vb-page-subtitle">Buses registered to @officeName.</p>
    </div>
    <a asp-controller="Bus" asp-action="Create" class="btn-vb-primary mt-1">
        <i class="bi bi-plus-lg"></i> Register Bus
    </a>
</div>

@if (!Model.Buses.Any())
{
    <div class="vb-card vb-empty">
        <div class="vb-empty-icon"><i class="bi bi-bus-front"></i></div>
        <div class="vb-empty-title">No buses registered</div>
        <div class="vb-empty-text">Register your first bus to assign it to trips.</div>
        <a asp-controller="Bus" asp-action="Create" class="btn-vb-primary"><i class="bi bi-plus-lg"></i> Register Bus</a>
    </div>
}
else
{
    <div class="d-flex align-items-center justify-content-between mb-3">
        <p class="mb-0 text-muted-vb" style="font-size:0.85rem;">
            <strong style="color:var(--vb-text);">@Model.Buses.Count</strong> buses for this office
        </p>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted-vb fs-sm">Sort by:</span>
            <select class="vb-input" style="width:auto;font-size:0.82rem;padding:0.35rem 0.7rem;">
                <option>Registration No.</option>
                <option>Capacity (High)</option>
                <option>Bus Type</option>
            </select>
        </div>
    </div>

    <div class="d-flex flex-column gap-3">
        @foreach (var bus in Model.Buses)
        {
            <div class="vb-card" style="padding:1.25rem 1.5rem;">
                <div class="row align-items-center g-3">
                    <div class="col">
                        <div class="d-flex align-items-center gap-3 mb-1">
                            <div style="width:38px;height:38px;border-radius:8px;background:var(--vb-tag-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                                <i class="bi bi-bus-front" style="color:var(--vb-navy);font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <div class="fw-700" style="font-size:0.95rem;font-family:monospace;color:var(--vb-navy);">
                                    @bus.RegistrationNumber
                                    <span class="vb-tag vb-tag-express ms-2" style="font-family:'Inter',sans-serif;">@bus.Type</span>
                                </div>
                                <div class="text-muted-vb fs-sm">Bus ID #@bus.BusId &bull; Office #@bus.OfficeId</div>
                            </div>
                        </div>
                        <div class="d-flex flex-wrap gap-3 mt-1" style="font-size:0.82rem;color:var(--vb-text-mid);">
                            <span><i class="bi bi-people-fill me-1"></i>@bus.Capacity seats</span>
                            <span class="text-green fw-600"><i class="bi bi-wifi me-1"></i>Wi-Fi</span>
                            <span class="text-green fw-600"><i class="bi bi-lightning-charge me-1"></i>Power Outlet</span>
                        </div>
                    </div>
                    <div class="col-auto d-flex flex-column align-items-end gap-2">
                        <a asp-controller="Bus" asp-action="Edit"
                           asp-route-id="@bus.BusId"
                           asp-route-officeId="@Model.OfficeId"
                           class="btn-vb-primary" style="font-size:0.82rem;padding:0.45rem 1rem;">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <span class="text-muted-vb fs-xs">Starting at @bus.Capacity seats</span>
                    </div>
                </div>
            </div>
        }
    </div>
}
