@model BusTicketSystem.MVC.ViewModels.CreateTripViewModel
@{
    ViewData["Title"] = "Schedule New Trip";
    var routes  = ViewBag.Routes  as List<BusTicketSystem.MVC.ViewModels.RouteViewModel>  ?? new();
    var buses   = ViewBag.Buses   as List<BusTicketSystem.MVC.ViewModels.BusViewModel>   ?? new();
    var drivers = ViewBag.Drivers as List<BusTicketSystem.MVC.ViewModels.DriverViewModel> ?? new();
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-9">
            <div class="vb-card p-4 p-lg-5 shadow-lg border-0">
                <div class="d-flex align-items-center gap-3 mb-5">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary">
                        <i class="bi bi-calendar-plus h3 mb-0"></i>
                    </div>
                    <div>
                        <h2 class="fw-bold mb-1">Schedule Journey</h2>
                        <p class="vb-text-muted mb-0">Link a route, bus, and driver to create a new trip.</p>
                    </div>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

                    <div class="row g-4">
                        <!-- Route Selection -->
                        <div class="col-md-12">
                            <div class="vb-form-group">
                                <label asp-for="RouteId" class="vb-form-label">Select Route</label>
                                <select asp-for="RouteId" class="vb-form-control">
                                    <option value="">-- Choose a Route --</option>
                                    @foreach (var route in routes)
                                    {
                                        <option value="@route.RouteId">@route.FromCity → @route.ToCity (@(route.EstimatedDurationMinutes / 60)h @(route.EstimatedDurationMinutes % 60)m)</option>
                                    }
                                </select>
                                <span asp-validation-for="RouteId" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Bus Selection -->
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="BusId" class="vb-form-label">Assign Bus</label>
                                <select asp-for="BusId" class="vb-form-control">
                                    <option value="">-- Choose a Bus --</option>
                                    @foreach (var bus in buses)
                                    {
                                        <option value="@bus.BusId">@bus.RegistrationNumber (@bus.BusType)</option>
                                    }
                                </select>
                                <span asp-validation-for="BusId" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Fare -->
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="Fare" class="vb-form-label">Ticket Fare (₹)</label>
                                <input asp-for="Fare" type="number" step="0.01" class="vb-form-control" placeholder="0.00" />
                                <span asp-validation-for="Fare" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Times -->
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="DepartureTime" class="vb-form-label">Departure Date &amp; Time</label>
                                <input asp-for="DepartureTime" type="datetime-local" class="vb-form-control" />
                                <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="ArrivalTime" class="vb-form-label">Estimated Arrival</label>
                                <input asp-for="ArrivalTime" type="datetime-local" class="vb-form-control" />
                                <span asp-validation-for="ArrivalTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Driver (single, as per API contract) -->
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="DriverId" class="vb-form-label">Assign Driver</label>
                                <select asp-for="DriverId" class="vb-form-control">
                                    <option value="">-- Assign a Driver --</option>
                                    @foreach (var driver in drivers)
                                    {
                                        <option value="@driver.DriverId">@driver.Name (@driver.LicenseNumber)</option>
                                    }
                                </select>
                                <span asp-validation-for="DriverId" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Boarding Address -->
                        <div class="col-md-6">
                            <div class="vb-form-group">
                                <label asp-for="BoardingAddressId" class="vb-form-label">Boarding Address ID</label>
                                <input asp-for="BoardingAddressId" type="number" class="vb-form-control" placeholder="e.g. 1" />
                                <span asp-validation-for="BoardingAddressId" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <hr class="my-5 opacity-10">

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Agency" class="vb-btn-ghost">Discard</a>
                        <button type="submit" class="vb-btn-primary px-5 py-3">Schedule Trip</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
