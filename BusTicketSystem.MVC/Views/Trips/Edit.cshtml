@model BusTicketSystem.MVC.ViewModels.EditTripViewModel
@{
    ViewData["Title"] = "Edit Trip";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="vb-content-box p-4">
                <div class="mb-4">
                    <h1 class="h3 fw-bold mb-1">Edit Trip Details</h1>
                    <p class="vb-muted">Update timing, pricing, or status for trip <strong class="text-primary">#@Model.TripId</strong>.</p>
                </div>

                <form asp-action="Edit" asp-route-id="@Model.TripId" method="post">
                    <div class="vb-form-group mb-3">
                        <label class="vb-form-label">Fare Amount ($)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted">$</span>
                            <input asp-for="Request.Fare" type="number" step="0.01" class="vb-form-control border-start-0">
                        </div>
                        <span asp-validation-for="Request.Fare" class="text-danger extra-small"></span>
                    </div>

                    <div class="vb-form-group mb-3">
                        <label class="vb-form-label">Departure Time</label>
                        <input asp-for="Request.DepartureTime" type="datetime-local" class="vb-form-control">
                    </div>

                    <div class="vb-form-group mb-3">
                        <label class="vb-form-label">Arrival Time</label>
                        <input asp-for="Request.ArrivalTime" type="datetime-local" class="vb-form-control">
                    </div>

                    <div class="vb-form-group mb-4">
                        <label class="vb-form-label">Trip Status</label>
                        <select asp-for="Request.Status" class="vb-form-control">
                            <option value="Scheduled">Scheduled</option>
                            <option value="Delayed">Delayed</option>
                            <option value="Cancelled">Cancelled</option>
                            <option value="Completed">Completed</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="vb-btn-primary justify-content-center">Save Changes</button>
                        <a asp-action="Manage" class="vb-btn-ghost text-center">Back to Dashboard</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
