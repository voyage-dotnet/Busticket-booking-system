@model BusTicketSystem.MVC.ViewModels.EditTripViewModel
@{
    ViewData["Title"] = "Edit Trip";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="vb-content-box p-4">
                <div class="mb-4 d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                        <i class="bi bi-pencil-square h4 mb-0"></i>
                    </div>
                    <div>
                        <h1 class="h3 fw-bold mb-1">Edit Trip</h1>
                        <p class="vb-muted mb-0">Update schedule or status for trip #@Model.TripId.</p>
                    </div>
                </div>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="TripId" />
                    
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="vb-form-label">Route</label>
                            <select asp-for="RouteId" asp-items="@Model.Routes" class="vb-form-control"></select>
                            <span asp-validation-for="RouteId" class="text-danger extra-small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Bus</label>
                            <select asp-for="BusId" asp-items="@Model.Buses" class="vb-form-control"></select>
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Driver</label>
                            <select asp-for="DriverId" asp-items="@Model.Drivers" class="vb-form-control"></select>
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Departure Time</label>
                            <input asp-for="DepartureTime" type="datetime-local" class="vb-form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Arrival Time</label>
                            <input asp-for="ArrivalTime" type="datetime-local" class="vb-form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Fare Amount ($)</label>
                            <input asp-for="Fare" type="number" step="0.01" class="vb-form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="vb-form-label">Status</label>
                            <select asp-for="Status" class="vb-form-control">
                                <option value="Scheduled">Scheduled</option>
                                <option value="Ongoing">Ongoing</option>
                                <option value="Completed">Completed</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-5">
                        <button type="submit" class="vb-btn-primary px-5">Save Changes</button>
                        <a asp-controller="Dashboard" asp-action="Agency" class="vb-btn-ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
