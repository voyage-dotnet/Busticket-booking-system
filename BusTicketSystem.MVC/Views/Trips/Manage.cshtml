@model BusTicketSystem.MVC.ViewModels.AgencyDashboardViewModel
@{
    ViewData["Title"] = "Agency Dashboard";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h2 fw-bold">Agency Dashboard</h1>
            <p class="vb-muted">Monitor trip occupancy and manage your fleet performance.</p>
        </div>
        <a asp-action="Create" class="vb-btn-primary">
            <i class="bi bi-plus-lg"></i> Schedule New Trip
        </a>
    </div>


    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="vb-stat-card">
                <div class="vb-stat-label">Total Trips</div>
                <div class="vb-stat-value">@Model.TotalTrips</div>
                <div class="vb-stat-sub">Active scheduled</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vb-stat-card">
                <div class="vb-stat-label">Avg. Occupancy</div>
                <div class="vb-stat-value">@Model.AvgOccupancy.ToString("F1")%</div>
                <div class="vb-stat-sub">Across all routes</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vb-stat-card">
                <div class="vb-stat-label">Tickets Sold</div>
                <div class="vb-stat-value">@Model.TotalTicketsSold</div>
                <div class="vb-stat-sub">Current booking cycle</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="vb-stat-card">
                <div class="vb-stat-label">Fleet Status</div>
                <div class="vb-stat-value">Active</div>
                <div class="vb-stat-sub text-success">All systems normal</div>
            </div>
        </div>
    </div>


    <div class="vb-content-box p-0 overflow-hidden">
        <div class="p-4 border-bottom bg-light bg-opacity-50">
            <h5 class="mb-0 fw-bold">Live Trip Monitoring</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Trip Details</th>
                        <th class="py-3">Departure</th>
                        <th class="py-3 text-center">Booked</th>
                        <th class="py-3" style="width: 200px;">Occupancy</th>
                        <th class="pe-4 py-3 text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trip in Model.Trips)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@trip.FromCity <i class="bi bi-arrow-right small text-muted mx-1"></i> @trip.ToCity</div>
                                <div class="extra-small text-muted mono">#@trip.TripId</div>
                            </td>
                            <td>
                                <div class="fw-bold">@trip.DepartureTime.ToString("MMM dd")</div>
                                <div class="vb-muted">@trip.DepartureTime.ToString("HH:mm")</div>
                            </td>
                            <td class="text-center">
                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary px-3">@trip.BookedSeats / @trip.TotalSeats</span>
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="progress flex-grow-1" style="height: 6px; border-radius: 3px;">
                                        @{
                                            var colorClass = trip.OccupancyPercentage > 80 ? "bg-success" : 
                                                             trip.OccupancyPercentage > 50 ? "bg-info" : "bg-warning";
                                        }
                                        <div class="progress-bar @colorClass" style="width: @trip.OccupancyPercentage%"></div>
                                    </div>
                                    <span class="extra-small fw-bold">@trip.OccupancyPercentage.ToString("F0")%</span>
                                </div>
                            </td>
                            <td class="pe-4 text-end">
                                <a asp-action="Edit" asp-route-id="@trip.TripId" class="vb-btn-ghost text-primary p-2" title="Edit Trip"><i class="bi bi-pencil-square"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
