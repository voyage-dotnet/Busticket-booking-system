@model BusTicketSystem.MVC.ViewModels.ReviewJourneyViewModel
@{
    ViewData["Title"] = "Review Your Journey - VoyaBus";
}

<div class="container py-5">
    <div class="vb-review-header d-flex align-items-center gap-3 mb-5">
        <i class="bi bi-bezier2 h2 mb-0"></i>
        <h1 class="h2 fw-bold mb-0">Review Your Journey</h1>
    </div>

    <div class="row g-5">
        <div class="col-lg-8">
            <div class="vb-content-box p-4 p-lg-5 mb-5">
                <div class="d-flex justify-content-between align-items-start mb-5">
                    <div>
                        <span class="badge bg-light text-muted border px-3 py-2 rounded-pill fw-bold extra-small text-uppercase">BUS @Model.Trip.BusNumber • EXPRESS</span>
                        <div class="text-muted small mt-3 fw-bold">@Model.Trip.DepartureTime.ToString("dddd, MMM dd, yyyy")</div>
                    </div>
                    <a asp-action="SelectSeat" asp-route-tripId="@Model.Trip.TripId" class="text-primary fw-bold small text-decoration-none">Change Trip</a>
                </div>

                <div class="vb-journey-timeline-vertical ms-2">
                    <div class="d-flex gap-4 mb-5 position-relative">
                        <div class="vb-timeline-node"></div>
                        <div class="vb-timeline-vertical-line"></div>
                        <div>
                            <div class="small text-muted fw-bold mb-1">08:30 AM</div>
                            <div class="h5 fw-bold mb-1">@Model.Trip.FromCity, Terminal B</div>
                            <div class="small text-muted">Bay 14 • Upper Level</div>
                        </div>
                    </div>
                    <div class="d-flex gap-4 mt-5">
                        <div class="vb-timeline-node destination"></div>
                        <div>
                            <div class="small text-muted fw-bold mb-1">11:45 AM</div>
                            <div class="h5 fw-bold mb-1">@Model.Trip.ToCity Terminal</div>
                            <div class="small text-muted">Main Entrance</div>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-4">Passenger Information</h5>
            <div class="vb-content-box p-4 mb-5">
                <div class="row g-4">
                    <div class="col-md-7">
                        <label class="vb-search-label mb-2">FULL NAME</label>
                        <input type="text" class="form-control bg-light border-0 py-3 rounded-3" value="Alexander Thompson" readonly>
                    </div>
                    <div class="col-md-5">
                        <label class="vb-search-label mb-2">SEAT PREFERENCE</label>
                        <div class="form-control bg-light border-0 py-3 rounded-3 d-flex justify-content-between align-items-center">
                            <span class="small fw-bold">Window (@Model.SeatNumber A)</span>
                            <i class="bi bi-person-workspace opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>

            <h5 class="fw-bold mb-4">Payment Method</h5>
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="vb-payment-card active p-4 rounded-4 border-2">
                        <div class="d-flex justify-content-between mb-4">
                            <i class="bi bi-credit-card h3 mb-0"></i>
                            <div class="vb-check-ring"><i class="bi bi-record-circle-fill"></i></div>
                        </div>
                        <div class="fw-bold small mb-1">Card ending in 4242</div>
                        <div class="extra-small text-muted">Exp: 12/26</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="vb-payment-card p-4 rounded-4 border">
                        <div class="d-flex justify-content-between mb-4">
                            <i class="bi bi-bank h3 mb-0 opacity-50"></i>
                            <div class="vb-check-ring opacity-25"><i class="bi bi-circle"></i></div>
                        </div>
                        <div class="fw-bold small mb-1">Apple Pay</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="vb-payment-card border-dashed p-4 rounded-4 d-flex flex-column align-items-center justify-content-center h-100 opacity-50">
                        <i class="bi bi-plus-lg h3 mb-2"></i>
                        <div class="small fw-bold">Add New</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="vb-content-box p-4 p-lg-5 mb-4">
                <h5 class="fw-bold mb-5">Fare Breakdown</h5>
                <div class="d-flex justify-content-between mb-3 pb-2 border-bottom border-light">
                    <span class="text-muted small">Base Fare (x1)</span>
                    <span class="fw-bold small">$42.00</span>
                </div>
                <div class="d-flex justify-content-between mb-3 pb-2 border-bottom border-light">
                    <span class="text-muted small">Seat Selection</span>
                    <span class="fw-bold small">$5.50</span>
                </div>
                <div class="d-flex justify-content-between mb-5">
                    <span class="text-muted small">Booking Fee</span>
                    <span class="fw-bold small">$2.00</span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <h4 class="fw-bold mb-0">Total Amount</h4>
                    <h4 class="fw-bold mb-0 text-primary">$@Model.Total.ToString("F2")</h4>
                </div>

                <form asp-controller="Booking" asp-action="Book" method="post">
                    <input type="hidden" name="TripId" value="@Model.Trip.TripId" />
                    <input type="hidden" name="SelectedSeat" value="@Model.SeatNumber" />
                    <button type="submit" class="btn btn-vb-dark w-100 py-3 fw-bold rounded-3 h5 mb-3">
                        Confirm & Pay <i class="bi bi-arrow-right ms-2"></i>
                    </button>
                </form>
                <p class="text-center extra-small text-muted mb-0">By clicking pay, you agree to our <a href="#" class="text-decoration-underline text-muted">Terms of Service</a>.</p>
            </div>

            <div class="vb-content-box p-4 rounded-4 border-0 mb-4 d-flex gap-4 align-items-center bg-light">
                <i class="bi bi-shield-lock h3 mb-0 opacity-50"></i>
                <div>
                    <div class="fw-bold small">Secure SSL Payment</div>
                    <div class="extra-small text-muted">256-bit encryption active</div>
                </div>
            </div>

            <div class="vb-notice-card-blue p-4 rounded-4 border-0 d-flex gap-4 align-items-start">
                <i class="bi bi-info-circle h3 mb-0"></i>
                <div>
                    <div class="fw-bold small">Cancellation Policy</div>
                    <div class="extra-small opacity-75">Full refund if cancelled at least 24 hours before departure time.</div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .vb-timeline-node { width: 14px; height: 14px; border: 2px solid #6366f1; border-radius: 50%; background: white; z-index: 1; }
    .vb-timeline-node.destination { border-color: #10b981; }
    .vb-timeline-vertical-line { position: absolute; left: 6px; top: 14px; width: 2px; height: 100px; background: #e2e8f0; z-index: 0; }
    .vb-payment-card { cursor: pointer; transition: all 0.2s; }
    .vb-payment-card.active { border-color: #334155 !important; background: rgba(51, 65, 85, 0.02); }
    .vb-payment-card:hover:not(.active) { border-color: #cbd5e1; }
    .border-dashed { border-style: dashed !important; }
    .vb-notice-card-blue { background: #eff6ff; color: #1e40af; }
    .btn-vb-dark { background: #334155; color: white; border: 0; }
    .btn-vb-dark:hover { background: #0f172a; color: white; }
</style>
