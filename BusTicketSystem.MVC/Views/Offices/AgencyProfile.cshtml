@model BusTicketSystem.MVC.ViewModels.PublicAgencyViewModel
@{
    ViewData["Title"] = Model.Name + " - Profile";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Agency Header Card -->
        <div class="col-12">
            <div class="vb-card p-4 p-lg-5 shadow-sm border-0 bg-primary text-white overflow-hidden position-relative">
                <div class="row align-items-center position-relative" style="z-index: 1;">
                    <div class="col-md-3 text-center text-md-start mb-4 mb-md-0">
                        <img src="~/images/agency-network.svg" alt="@Model.Name operations" class="img-fluid bg-white rounded-3 p-2" style="max-height: 150px;" />
                    </div>
                    <div class="col-md-6 text-center text-md-start">
                        <h1 class="fw-bold mb-1">@Model.Name</h1>
                        <p class="mb-0 opacity-75">Partnering with VoyaBus since 2024</p>
                        <div class="mt-3">
                            <span class="vb-badge vb-badge-verified px-3 py-1 bg-white text-primary border-0">Verified Operator</span>
                            <span class="ms-2 small fw-bold">
                                <i class="bi bi-star-fill text-warning me-1"></i> 
                                @(Model.Rating > 0 ? Model.Rating.ToString("F1") : "New") Operator
                            </span>
                        </div>
                    </div>
                    <div class="col-md-3 text-center text-md-end mt-4 mt-md-0">
                        <a asp-controller="Trips" asp-action="Index" class="btn btn-light px-4 py-3 fw-bold vb-radius-md">
                            Book Tickets Now
                        </a>
                    </div>
                </div>
                <!-- Decoration -->
                <i class="bi bi-bus-front position-absolute end-0 bottom-0 text-white opacity-10" style="font-size: 15rem; margin-right: -2rem; margin-bottom: -3rem;"></i>
            </div>
        </div>

        <!-- Left Column: About & Contact -->
        <div class="col-lg-4">
            <div class="vb-card p-4 mb-4 border-0 shadow-sm">
                <h5 class="fw-bold mb-4">About the Agency</h5>
                <p class="vb-text-secondary small mb-4">@(string.IsNullOrEmpty(Model.Description) ? "Professional bus transit service providing comfortable and safe journeys across multiple routes." : Model.Description)</p>
                
                <h6 class="fw-bold mb-3 small text-uppercase text-muted">Contact Information</h6>
                <div class="d-flex align-items-center gap-3 mb-3 small">
                    <div class="bg-light p-2 rounded-2 text-primary"><i class="bi bi-envelope"></i></div>
                    <div>@Model.Email</div>
                </div>
                <div class="d-flex align-items-center gap-3 mb-3 small">
                    <div class="bg-light p-2 rounded-2 text-primary"><i class="bi bi-telephone"></i></div>
                    <div>@Model.Phone</div>
                </div>
            </div>

            <div class="vb-card p-4 border-0 shadow-sm">
                <h5 class="fw-bold mb-4">Fleet Details</h5>
                <div class="row text-center">
                    <div class="col-12">
                        <div class="h3 fw-bold text-primary mb-0">@Model.TotalBuses</div>
                        <div class="extra-small text-muted text-uppercase fw-bold">Active Fleet Size</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Services & Highlights -->
        <div class="col-lg-8">
            <div class="vb-card p-4 p-lg-5 border-0 shadow-sm h-100">
                <h5 class="fw-bold mb-5">Why Choose @Model.Name?</h5>
                
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-check-circle-fill text-success h4 mb-0"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Punctual Services</h6>
                                <p class="vb-text-secondary small">Average delay less than 10 minutes across all routes.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-check-circle-fill text-success h4 mb-0"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Modern Fleet</h6>
                                <p class="vb-text-secondary small">All buses are equipped with AC, Wi-Fi, and Charging Points.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-check-circle-fill text-success h4 mb-0"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Safety First</h6>
                                <p class="vb-text-secondary small">Verified drivers with 10+ years of highway experience.</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex gap-3">
                            <i class="bi bi-check-circle-fill text-success h4 mb-0"></i>
                            <div>
                                <h6 class="fw-bold mb-1">24/7 Support</h6>
                                <p class="vb-text-secondary small">Dedicated support desk for all @Model.Name passengers.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-5 border-top">
                    <div class="vb-card-notice bg-light border-0 d-flex justify-content-between align-items-center">
                        <div class="small">Looking for schedules for this operator?</div>
                        <a asp-controller="Trips" asp-action="Index" class="fw-bold text-primary text-decoration-none small">View All Trips <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05em; }
</style>
