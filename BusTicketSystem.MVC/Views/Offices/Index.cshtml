@model List<BusTicketSystem.MVC.ViewModels.OfficeViewModel>
@{
    ViewData["Title"] = "Branch Offices";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <h1 class="h2 fw-bold mb-1">Our Offices</h1>
            <p class="vb-text-muted mb-0">Manage your branch locations and terminal contact points.</p>
        </div>
        <a asp-action="Create" class="vb-btn-primary">
            <i class="bi bi-geo-alt"></i> Add New Office
        </a>
    </div>

    <div class="row g-4">
        @if (Model.Count == 0)
        {
            <div class="col-12 text-center py-5">
                <div class="vb-card p-5 border-0 shadow-sm">
                    <i class="bi bi-building h1 text-muted opacity-25 mb-3 d-block"></i>
                    <h5 class="fw-bold">No offices registered</h5>
                    <p class="vb-text-muted small">Register your first branch to help passengers find you.</p>
                </div>
            </div>
        }
        @foreach (var office in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="vb-card h-100 shadow-sm border-0">
                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                                <i class="bi bi-geo-fill h4 mb-0"></i>
                            </div>
                            <span class="vb-badge vb-badge-verified">OFFICE #@office.OfficeId</span>
                        </div>
                        
                        <h5 class="fw-bold mb-3">@office.OfficeContactPersonName</h5>
                        
                        <div class="vb-text-muted extra-small text-uppercase fw-bold mb-1">Contact Details</div>
                        <div class="small mb-1"><i class="bi bi-envelope me-2"></i> @office.OfficeMail</div>
                        <div class="small mb-4"><i class="bi bi-telephone me-2"></i> @office.OfficeContactNumber</div>

                        <div class="vb-text-muted extra-small text-uppercase fw-bold mb-1">Location</div>
                        <div class="small"><i class="bi bi-map me-2"></i> @office.Address</div>
                    </div>
                    <div class="p-3 border-top bg-light d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@office.OfficeId" class="vb-btn-ghost py-1 px-3 small border w-100 text-center text-decoration-none">Edit Details</a>
                        <a asp-action="AgencyProfile" asp-route-id="@office.AgencyId" class="vb-btn-ghost py-1 px-3 small border w-100 text-center text-decoration-none text-primary"><i class="bi bi-eye me-1"></i> Public View</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .extra-small { font-size: 0.65rem; letter-spacing: 0.05em; }
</style>
