@model BusTicketSystem.MVC.Models.Trip.TripSearchViewModel
@{ ViewData["Title"] = "Search Results"; }

<div class="vb-page">
    <h1 class="vb-section-title" style="font-size:var(--vb-font-size-xl);">
        @Model.From → @Model.To
    </h1>
    <p class="vb-muted mb-4">@Model.Date.ToString("MMM dd, yyyy")</p>

    @if (!Model.Results.Any())
    {
        <div class="vb-card text-center py-5">
            <p class="vb-muted">No trips found for this route and date.</p>
            <a asp-controller="Home" asp-action="Index" class="vb-btn-primary">Search Again</a>
        </div>
    }
    else
    {
        <div class="vb-results-bar">
            <span><span class="vb-results-count">@Model.Results.Count</span> trip(s) found</span>
            <select class="vb-sort-select">
                <option>Sort: Earliest departure</option>
                <option>Sort: Lowest price</option>
                <option>Sort: Fastest journey</option>
            </select>
        </div>

        @foreach (var trip in Model.Results)
        {
            <div class="vb-trip-card">
                <div class="d-flex justify-content-between align-items-center">
                    <!-- Times -->
                    <div class="d-flex align-items-center gap-3">
                        <div>
                            <div class="vb-trip-time">@trip.DepartureTime.ToString("hh:mm tt")</div>
                            <div class="vb-trip-station">@trip.FromCity</div>
                        </div>
                        <div class="text-center px-2">
                            <div class="vb-trip-duration">──────</div>
                            <div class="vb-trip-stops">@trip.AgencyName</div>
                        </div>
                        <div>
                            <div class="vb-trip-time">@trip.ArrivalTime.ToString("hh:mm tt")</div>
                            <div class="vb-trip-station">@trip.ToCity</div>
                        </div>
                    </div>

                    <!-- Bus type & seats -->
                    <div class="text-center d-none d-md-block">
                        <div class="vb-badge vb-badge-verified">@trip.BusType</div>
                        <div class="vb-muted mt-1">@trip.AvailableSeats seats left</div>
                    </div>

                    <!-- Price & CTA -->
                    <div class="text-end">
                        <div class="vb-trip-price">
                            <span class="vb-trip-price-label">from</span>
                            <span class="vb-trip-price-amount" style="font-size:1.3rem;">
                                ₹@trip.Fare.ToString("F2")
                            </span>
                        </div>
                        <a asp-controller="Booking" asp-action="SelectSeat"
                           asp-route-tripId="@trip.TripId"
                           asp-route-routeName="@(trip.FromCity + " -> " + trip.ToCity)"
                           asp-route-departureTime="@trip.DepartureTime.ToString("o")"
                           asp-route-fare="@trip.Fare"
                           class="vb-btn-select mt-2 d-inline-block">
                            Select Seats →
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>
